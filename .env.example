# NLEARN / Moodle configuration
#
# Copy this file to `.env` and fill in real values.
#
# IMPORTANT:
# - Do not commit `.env` to git (it must be gitignored).
# - If you suspect credentials were committed historically, rotate your password.

# Base URL of your NLearn / Moodle instance (no trailing slash)
NLEARN_URL="https://moodle.example.edu"

# Login credentials for your account
NLEARN_USERNAME="your_username"
NLEARN_PASSWORD="your_password"

# Optional: only needed if you enable live integration tests locally.
# RUN_LIVE_INTEGRATION_TESTS="1"

